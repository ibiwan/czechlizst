{
  "name": "czhechlizst",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run types:generate && concurrently -n types,frontend -c magenta,cyan \"npm run types:watch\" \"npm run dev:frontend\"",
    "dev:full": "npm run postgrest:start && npm run dev",
    "dev:frontend": "npm run dev -w @app/frontend",
    "dev:mcp": "npm run dev -w @app/mcp-server",
    "types:generate": "npm run prisma:generate -w @app/db && npm run prisma:types -w @app/db",
    "types:check": "node ./scripts/check-generated-types.mjs",
    "types:watch": "npm run prisma:types:watch -w @app/db",
    "doctor": "node ./scripts/doctor.mjs",
    "check:all": "npm run doctor && npm run types:check && npm run lint && npm run test:all && npm run build",
    "postgrest:up": "docker compose -f apps/backend/docker-compose.yml up -d",
    "postgrest:start": "npm run postgrest:up && npm run prisma:migrate:deploy && docker compose -f apps/backend/docker-compose.yml restart postgrest",
    "postgrest:down": "docker compose -f apps/backend/docker-compose.yml down",
    "postgrest:logs": "docker compose -f apps/backend/docker-compose.yml logs -f",
    "build": "npm run types:generate && npm run build -w @app/frontend && npm run build -w @app/contracts && npm run build -w @app/db",
    "build:mcp": "npm run build -w @app/mcp-server",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "“npm run test -ws --if-present",
    "test:frontend": "npm run test -w @app/frontend",
    "test:frontend:coverage": "npm run test -w @app/frontend -- --coverage",
    "test:postgrest:e2e": "vitest run --config apps/backend/vitest.config.mts",
    "test:postgrest:e2e:watch": "vitest --config apps/backend/vitest.config.mts",
    "test:coverage": "npm run test:frontend:coverage",
    "test:all": "npm run test:frontend && npm run test:postgrest:e2e",
    "prisma:generate": "npm run prisma:generate -w @app/db",
    "prisma:migrate": "npm run prisma:migrate -w @app/db",
    "prisma:migrate:deploy": "npm run prisma:migrate:deploy -w @app/db",
    "mcp:start": "npm run start -w @app/mcp-server",
    "db:export:json": "node ./scripts/db-export-json.mjs",
    "db:import:json": "node ./scripts/db-import-json.mjs",
    "db:seed:demo": "npm run db:import:json -- data/snapshots/demo-wide.json"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.1.2",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "playwright": "^1.58.2",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.9"
  }
}
