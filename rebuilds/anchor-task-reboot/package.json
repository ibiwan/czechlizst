{
  "name": "anchor-task-reboot",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "node ../../node_modules/vite/bin/vite.js",
    "preview": "node ../../node_modules/vite/bin/vite.js preview",
    "build": "node ../../node_modules/typescript/bin/tsc --noEmit && node ../../node_modules/vite/bin/vite.js build",
    "test": "node ../../node_modules/vitest/vitest.mjs run --config ./vitest.config.ts",
    "test:coverage": "node ../../node_modules/vitest/vitest.mjs run --config ./vitest.config.ts --coverage",
    "test:all": "npm run test",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "format": "npx prettier --check .",
    "format:write": "npx prettier --write .",
    "types:generate": "node ./scripts/generate-types.mjs",
    "types:check": "node ./scripts/check-generated-types.mjs",
    "types:watch": "node --watch ./scripts/generate-types.mjs",
    "contracts:generate": "npm run types:generate",
    "contracts:check": "npm run types:check",
    "contracts:watch": "npm run types:watch",
    "doctor": "npm run check:all",
    "db:export:json": "node ./scripts/db-export-json.mjs",
    "db:import:json": "node ./scripts/import-current-json.mjs",
    "db:up": "docker compose -f ./backend/docker-compose.yml up -d",
    "db:down": "docker compose -f ./backend/docker-compose.yml down",
    "db:import:current-json": "node ./scripts/import-current-json.mjs",
    "convert:backup": "node ./scripts/convert-backup-to-current-json.mjs",
    "prisma:validate": "node ../../node_modules/prisma/build/index.js validate --schema ./prisma/schema.prisma",
    "prisma:generate": "node ../../node_modules/prisma/build/index.js generate --schema ./prisma/schema.prisma",
    "prisma:migrate:deploy": "node ../../node_modules/prisma/build/index.js migrate deploy --schema ./prisma/schema.prisma",
    "db:start": "npm run db:up && npm run prisma:migrate:deploy && docker compose -f ./backend/docker-compose.yml restart postgrest",
    "dev:full": "npm run db:start && npm run dev",
    "check:all": "npm run lint && npm run test:all && npm run build"
  },
  "dependencies": {
    "@ariakit/react": "^0.4.24",
    "@prisma/client": "^6.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "prisma": "^6.5.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.1"
  }
}