generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["api"]
}

enum WorkStatus {
  todo
  started
  active
  done
  dropped

  @@schema("api")
}

enum TaskRelationType {
  blocked_by
  has_subtask
  related_to

  @@schema("api")
}

model Project {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  tasks     Task[]
  notes     ProjectNote[]

  @@map("projects")
  @@schema("api")
}

model Task {
  id               Int            @id @default(autoincrement())
  projectId        Int            @map("project_id")
  title            String
  isPlaceholder    Boolean        @default(false) @map("is_placeholder")
  status           WorkStatus     @default(todo)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @default(now()) @updatedAt @map("updated_at")
  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  notes            TaskNote[]
  relations        TaskRelation[] @relation("TaskRelations_Task")
  relatedBy        TaskRelation[] @relation("TaskRelations_RelatedTask")

  @@index([projectId])
  @@map("tasks")
  @@schema("api")
}

model TaskRelation {
  id            Int              @id @default(autoincrement())
  taskId        Int              @map("task_id")
  relatedTaskId Int              @map("related_task_id")
  relationType  TaskRelationType @map("relation_type")
  commentary    String?
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @default(now()) @updatedAt @map("updated_at")
  task          Task             @relation("TaskRelations_Task", fields: [taskId], references: [id], onDelete: Cascade)
  relatedTask   Task             @relation("TaskRelations_RelatedTask", fields: [relatedTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, relatedTaskId, relationType])
  @@index([taskId])
  @@index([relatedTaskId])
  @@index([relationType])
  @@map("task_relations")
  @@schema("api")
}

model ProjectNote {
  id        Int      @id @default(autoincrement())
  projectId Int      @map("project_id")
  body      String
  referenceUrl String? @map("reference_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@map("project_notes")
  @@schema("api")
}

model TaskNote {
  id        Int      @id @default(autoincrement())
  taskId    Int      @map("task_id")
  body      String
  referenceUrl String? @map("reference_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@map("task_notes")
  @@schema("api")
}
