generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["api"]
}

enum WorkStatus {
  todo
  started
  active
  done
  dropped

  @@schema("api")
}

model Project {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  tasks     Task[]
  notes     ProjectNote[]

  @@map("projects")
  @@schema("api")
}

model Task {
  id          Int           @id @default(autoincrement())
  projectId   Int           @map("project_id")
  title       String
  isPlaceholder Boolean     @default(false) @map("is_placeholder")
  status      WorkStatus    @default(todo)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @default(now()) @updatedAt @map("updated_at")
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  notes       TaskNote[]
  blockers    TaskBlocker[] @relation("TaskBlockers_Task")
  blockingFor TaskBlocker[] @relation("TaskBlockers_BlockingTask")

  @@index([projectId])
  @@map("tasks")
  @@schema("api")
}

model TaskBlocker {
  id             Int      @id @default(autoincrement())
  taskId         Int      @map("task_id")
  blockingTaskId Int      @map("blocking_task_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")
  task           Task     @relation("TaskBlockers_Task", fields: [taskId], references: [id], onDelete: Cascade)
  blockingTask   Task     @relation("TaskBlockers_BlockingTask", fields: [blockingTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, blockingTaskId])
  @@index([taskId])
  @@index([blockingTaskId])
  @@map("task_blockers")
  @@schema("api")
}

model ProjectNote {
  id        Int      @id @default(autoincrement())
  projectId Int      @map("project_id")
  body      String
  referenceUrl String? @map("reference_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@map("project_notes")
  @@schema("api")
}

model TaskNote {
  id        Int      @id @default(autoincrement())
  taskId    Int      @map("task_id")
  body      String
  referenceUrl String? @map("reference_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@map("task_notes")
  @@schema("api")
}
